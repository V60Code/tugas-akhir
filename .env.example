# --- Database (Jangan diubah agar connect ke Docker) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sql_optimizer

# --- MinIO / Storage (Default Docker) ---
# These map to MINIO_ACCESS_KEY / MINIO_SECRET_KEY in docker-compose.yml.
# MinIO container uses them as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD internally.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Security ---
# Ganti ini dengan string acak apa saja (bebas)
SECRET_KEY=rahasia_dapur_project_ini_12345
# Password untuk Flower dashboard (http://localhost:5555).
# Username default: admin (dapat diganti via FLOWER_USER).
FLOWER_PASSWORD=ganti_dengan_password_aman

# --- External Services (PENTING) ---
# 1. Isi dengan key asli dari Google AI Studio.
# 2. Jangan commit file `.env` ke repository.
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Model gratis/recommended Gemini Flash
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Connection Strings (Auto-generated based on above) ---
# Pastikan formatnya: postgresql+asyncpg://USER:PASS@db:5432/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sql_optimizer
REDIS_URL=redis://redis:6379/0
